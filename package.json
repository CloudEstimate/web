{
  "name": "cloudestimate-web",
  "version": "0.1.0",
  "description": "Static utility for sizing self-managed enterprise workloads across Google Cloud, AWS, and Azure.",
  "repository": {
    "type": "git",
    "url": "https://github.com/CloudEstimate/web.git"
  },
  "author": "Regnard Raquedan",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run ensure:caches && npm run generate:assets && astro build",
    "preview": "astro preview",
    "lint": "astro check",
    "test": "vitest run",
    "validate:isvs": "node scripts/validate-isvs.mjs",
    "validate:terraform": "node scripts/validate-terraform.mjs",
    "check:functions": "npm --prefix functions run check",
    "fetch:caches": "node scripts/fetch-caches.mjs",
    "refresh:pricing:snapshot": "node functions/scripts/refresh-pricing-snapshot.mjs",
    "regenerate:explanations:snapshot": "node functions/scripts/regenerate-explanations-snapshot.mjs",
    "generate:assets": "node scripts/generate-assets.mjs",
    "ensure:caches": "node scripts/ensure-generated-caches.mjs",
    "sync:functions-data": "node scripts/sync-functions-data.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.1.6",
    "@astrojs/tailwind": "^5.1.0",
    "@google-cloud/storage": "^7.16.0",
    "@resvg/resvg-js": "^2.6.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "astro": "^4.16.18",
    "tailwindcss": "^3.4.17",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
