---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import IsvCard from "@/components/IsvCard.astro";
import { buildCanonical } from "@/lib/seo";
import { siteConfig } from "@/lib/site";

const isvs = await getCollection("isvs");
---

<BaseLayout
  title="Size self-managed workloads across clouds. | CloudEstimate"
  description={siteConfig.description}
  canonical={buildCanonical("/")}
>
  <section class="page-shell py-12 lg:py-16">
    <div class="home-hero">
      <h1>Size self-managed workloads across clouds.</h1>
      <p>
        Reference-architecture-based sizing and monthly cost estimates for Google Cloud, AWS, and Azure.
      </p>
    </div>

    <div class="mt-10">
      <div class="home-filter-grid">
        <div>
          <label class="field-label" for="isv-filter">Filter ISVs</label>
          <input
            class="w-full rounded-[6px] border px-3 py-2 text-sm"
            style="border-color: var(--color-border);"
            id="isv-filter"
            type="search"
            placeholder="Filter by ISV or vendor"
          />
        </div>
        <p class="home-filter-note">No signup, no guessing.</p>
      </div>
    </div>

    <div class="home-results-divider" aria-live="polite">
      <div class="home-results-meta">
        <span class="home-results-label">Available workloads</span>
        <span class="home-results-count" id="isv-count">{isvs.length} shown</span>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3" id="isv-grid">
      {isvs.map((isv) => (
        <div data-filter-card={`${isv.data.name} ${isv.data.vendor} ${isv.data.slug}`.toLowerCase()}>
          <IsvCard isv={isv} />
        </div>
      ))}
    </div>

    <div class="home-insights">
      <div class="grid gap-8 lg:grid-cols-3">
        <section class="insight-card">
          <p class="insight-card-kicker">How it works</p>
          <h2>Reference architecture in, estimate out.</h2>
          <p>
            Published vendor reference architectures are mapped to cloud instance shapes, then priced against cached regional snapshots. The page loads with a default estimate and keeps the full state in the URL.
          </p>
        </section>
        <section class="insight-card">
          <p class="insight-card-kicker">What&apos;s not modelled</p>
          <h2>Useful constraints, stated plainly.</h2>
          <ul>
            <li>Vendor licensing and support</li>
            <li>Network egress and backups</li>
            <li>Compliance controls and DR topologies</li>
          </ul>
        </section>
        <section class="insight-card">
          <p class="insight-card-kicker">Who built this</p>
          <h2>Built as a focused, opinionated utility.</h2>
          <p>
            CloudEstimate is a personal project by Regnard Raquedan. The short version and the links are on <a href="/about">About</a>.
          </p>
        </section>
      </div>
    </div>
  </section>

  <script is:inline>
    const input = document.getElementById("isv-filter");
    const cards = Array.from(document.querySelectorAll("[data-filter-card]"));
    const count = document.getElementById("isv-count");

    input?.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const matches = card.dataset.filterCard.includes(query);
        card.style.display = matches ? "" : "none";
        if (matches) {
          visible += 1;
        }
      });
      if (count) {
        count.textContent = `${visible} shown`;
      }
    });
  </script>
</BaseLayout>
